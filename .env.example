# Copy to .env and fill in (the .env file is git-ignored).
# The app works without any keys — they progressively upgrade the visuals.

# Detailed basemap (day + dark). https://cloud.maptiler.com/account/keys — free tier
MAPTILER_KEY=

# Google photorealistic 3D buildings. Needs "Map Tiles API" enabled + billing:
# https://console.cloud.google.com/google/maps-apis (Photorealistic 3D Tiles)
GOOGLE_MAPS_API_KEY=

# Server port (optional)
# PORT=8787
